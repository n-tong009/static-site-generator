{
  "name": "static-site-generator",
  "version": "1.0.0",
  "description": "LP納品用静的サイトジェネレータ",
  "type": "module",
  "scripts": {
    "dev": "node build/dev.js",
    "build": "BUILD_ENV=production NODE_ENV=production node build/build.js",
    "build:stg": "BUILD_ENV=staging NODE_ENV=production node build/build.js",
    "build:prod": "BUILD_ENV=production NODE_ENV=production node build/build.js",
    "preview": "vite preview --outDir dist"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ejs": "^3.1.9",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.3",
    "gray-matter": "^4.0.3",
    "sass": "^1.66.1",
    "vite": "^6.3.4"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
