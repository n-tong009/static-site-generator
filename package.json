{
  "name": "static-site-generator",
  "version": "1.0.0",
  "description": "LP納品用静的サイトジェネレータ",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "BUILD_ENV=production NODE_ENV=production node scripts/build.js",
    "build:stg": "BUILD_ENV=staging NODE_ENV=production node scripts/build.js",
    "build:prod": "BUILD_ENV=production NODE_ENV=production node scripts/build.js",
    "preview": "vite preview --outDir dist",
    "verify": "node scripts/verify-build.js",
    "new-page": "node scripts/new-page.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:js": "node -e \"import('./src/scripts/pages/_index.js').then(m => console.log('pages exports:', Object.keys(m)))\""
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "sass": "^1.99.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ejs": "1.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
