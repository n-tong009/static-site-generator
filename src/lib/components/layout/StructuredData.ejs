<%
const _type = typeof structuredType !== 'undefined' ? structuredType : 'Organization'
let _jsonld = null

function resolveSiteUrl(value) {
  if (!value) return SITE_CONFIG.url
  if (/^[a-z][a-z\d+.-]*:/i.test(value)) return value

  const base = SITE_CONFIG.url.endsWith('/') ? SITE_CONFIG.url : `${SITE_CONFIG.url}/`
  const relative = String(value).replace(/^\/+/, '')
  return new URL(relative, base).href
}

if (_type === 'Organization') {
  _jsonld = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: data.site.companyName,
    url: SITE_CONFIG.url,
    logo: resolveSiteUrl('/images/og.jpg'),
  }
  if (data.site.tel) _jsonld.telephone = data.site.tel
  if (data.site.email) _jsonld.email = data.site.email
  if (data.site.address) _jsonld.address = { '@type': 'PostalAddress', streetAddress: data.site.address }
  if (data.site.sns) {
    const sameAs = Object.values(data.site.sns).filter(Boolean)
    if (sameAs.length) _jsonld.sameAs = sameAs
  }
} else if (_type === 'FAQPage' && data.faq && data.faq.items) {
  _jsonld = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: data.faq.items.map(function (item) {
      return {
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      }
    }),
  }
}
%>
<% if (_jsonld) { %>
<script type="application/ld+json">
  <%- JSON.stringify(_jsonld) %>
</script>
<% } %>
