<%
// Head.ejs
const {
  title = DEFAULT_PAGE_META.title,
  description = DEFAULT_PAGE_META.description,
  ogType = DEFAULT_PAGE_META.ogType,
  ogImage = DEFAULT_PAGE_META.ogImage,
  noindex: _noindexLocal = undefined,
  nofollow = false,
  pagePath,
  preconnect = [],
  preload = [],
  structuredType = 'Organization',
  customHead = ''
} = locals
// STG 環境はデフォルト noindex。frontmatter で明示的に noindex: false を指定すれば上書き可
const noindex = _noindexLocal !== undefined ? _noindexLocal : getCurrentEnv() === 'STG'

function renderPreloadAttr(name, value) {
  return `${name}="${escapeAttr(value)}"`
}

function resolveSiteUrl(value) {
  if (!value) return SITE_CONFIG.url
  if (/^[a-z][a-z\d+.-]*:/i.test(value)) return value

  const base = SITE_CONFIG.url.endsWith('/') ? SITE_CONFIG.url : `${SITE_CONFIG.url}/`
  const relative = String(value).replace(/^\/+/, '')
  return new URL(relative, base).href
}

// URLパスの生成
const canonicalURL = resolveSiteUrl(pagePath)
const ogImageURL = resolveSiteUrl(ogImage)

function escapeAttr(value) {
  const replacements = {
    '&': '&amp;',
    '"': '&quot;',
    "'": '&#39;',
    '<': '&lt;',
  }

  return String(value).replace(/[&"'<]/g, function (char) {
    return replacements[char]
  })
}

function renderPreloadLink(item) {
  const attrs = ['rel="preload"', renderPreloadAttr('href', item.href), renderPreloadAttr('as', item.as)]

  if (item.type) attrs.push(renderPreloadAttr('type', item.type))
  if (item.fetchpriority) attrs.push(renderPreloadAttr('fetchpriority', item.fetchpriority))
  if (item.crossorigin) attrs.push('crossorigin')

  return [String.fromCharCode(60) + 'link', ...attrs].join(' ') + String.fromCharCode(62)
}
%>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5" />
  <title><%= title %> | <%= SITE_CONFIG.name %></title>

  <!-- SEO関連 -->
  <meta name="description" content="<%= description %>" />
  <meta name="robots" content="<%= `${noindex ? 'noindex' : 'index'},${nofollow ? 'nofollow' : 'follow'}` %>" />
  <link rel="canonical" href="<%= canonicalURL %>" />

  <!-- セキュリティ -->
  <% if (!isDev) { %>
  <meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com; frame-src https://www.googletagmanager.com; font-src 'self' data:"
  />
  <% } %>
  <meta name="referrer" content="strict-origin-when-cross-origin" />

  <!-- 書式の自動検出防止 -->
  <meta name="format-detection" content="telephone=no,address=no,email=no" />

  <!-- OGP (Facebook, その他のSNS) -->
  <meta property="og:type" content="<%= ogType %>" />
  <meta property="og:site_name" content="<%= SITE_CONFIG.name %>" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= description %>" />
  <meta property="og:url" content="<%= canonicalURL %>" />
  <meta property="og:image" content="<%= ogImageURL %>" />
  <meta property="og:locale" content="<%= SITE_CONFIG.locale %>" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="<%= SEO_DEFAULTS.twitterCard %>" />
  <meta name="twitter:title" content="<%= title %>" />
  <meta name="twitter:description" content="<%= description %>" />
  <meta name="twitter:image" content="<%= ogImageURL %>" />

  <!-- アイコン -->
  <link rel="icon" href="<%= PATHS.images.favicon %>.ico" sizes="32x32" />
  <link rel="icon" href="<%= PATHS.images.favicon %>.png" type="image/png" sizes="192x192" />
  <link rel="icon" href="<%= PATHS.images.favicon %>.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="<%= PATHS.images.appleTouchIcon %>" />

  <!-- preconnect / preload (frontmatter から) -->
  <% for (const href of preconnect) { %>
  <link rel="preconnect" href="<%= href %>" crossorigin />
  <% } %>
  <% for (const item of preload) { %>
  <%- renderPreloadLink(item) %>
  <% } %>

  <!-- スタイルシート (CDN base = ASSETS_URL[env]) -->
  <% if (isDev) { %>
  <link rel="stylesheet" href="<%= getCurrentAssetsUrl() %>scss/main.scss" />
  <script type="module" src="<%= getCurrentAssetsUrl() %>scripts/main.js"></script>
  <% } else { %>
  <link rel="stylesheet" href="<%= getCurrentAssetsUrl() %>assets/css/main.css" />
  <script type="module" src="<%= getCurrentAssetsUrl() %>assets/js/main.js"></script>
  <% } %>

  <!-- スロットの代わりにカスタムヘッド要素 -->
  <%- customHead %>

  <!-- Analytics (PROD のみ出力) -->
  <%- include('./Analytics.ejs', { position: 'head' }) %>

  <!-- 構造化データ (JSON-LD) -->
  <%- include('./StructuredData.ejs', { structuredType }) %>
</head>
